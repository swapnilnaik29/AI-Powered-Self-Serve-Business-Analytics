APP_NAME=Self-Serve Analytics BI
APP_VERSION=1.0.0
DEBUG=true

DATABASE_URL=sqlite:///./data/analytics.db

JWT_SECRET_KEY=dev-secret-key-change-in-production-abc123
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1024

CORS_ORIGINS=["http://localhost:4200","http://127.0.0.1:4200","http://0.0.0.0:4200"]

EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

RATE_LIMIT_PER_MINUTE=30

PAYMENTS_DB_PATH=data/payments.db
PAYMENTS_ROW_COUNT=15000
